{
    "version": 6,
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "llvm-clang-debug",
            "displayName": "LLVM Clang – Debug",
            "description": "Standalone LLVM Clang (C:\\Program Files\\LLVM\\bin), Debug build",
