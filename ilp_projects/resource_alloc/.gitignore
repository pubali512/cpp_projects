# Ignore build artifacts and IDE files for CMake/C++ projects

# Generated LP files 
*.lp

# Build directories
/build/
/build-*/

# CMake files
/CMakeFiles/
/CMakeCache.txt
/cmake_install.cmake
/Makefile
/compile_commands.json
install_manifest.txt

# Ninja files
build/*.ninja
rules.ninja

# External build directories
/external/**/build/

# Visual Studio
.vs/
*.vcxproj.user
*.suo
*.user
*.VC.db
*.VC.VC.opendb

# VS Code and JetBrains
.vscode/
.idea/
*.code-workspace

# Compiled object files, libraries, and executables
*.o
*.obj
*.lo
*.la
*.lai
*.a
*.lib
*.dll
*.exe
*.so
*.dylib
*.pdb

# Coverage, logs, temporary files
*.log
*.tmp
*.temp
*.bak
*.swp

# macOS and Windows system files
.DS_Store
Thumbs.db
Desktop.ini

# IntelliSense and compile database
*.i*db
ipch/

# Misc
tags
ctags
